# Kalshi uses RSA request signing. Keep the private key in a separate file.
KALSHI_ACCESS_KEY_ID=your_access_key_id_here
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_private_key.pem
POLYMARKET_API_KEY=your_key_here
POLYMARKET_CLOB_URL=https://clob.polymarket.com
NEWSAPI_KEY=your_key_here
FRED_API_KEY=your_key_here
CENSUS_API_KEY=your_key_here
DATABASE_PATH=./data/tapestry.duckdb
MODEL_PATH=./data/models/
LOG_LEVEL=INFO
ADMIN_PORT=8502
API_PORT=8000
